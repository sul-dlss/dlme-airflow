#!/usr/bin/env python3
"""Split all data.json files in working/ into individual record files.

For each data.json found, creates a sibling directory named YYYYMMDDHHMM
(based on the file's modification time) and writes one {id}.json per record.
"""
import argparse
import logging
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

from dlme_airflow.utils.split_data import split_data_file


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--working-dir",
        default="working",
        help="Root directory to search for data.json files (default: working)",
    )
    parser.add_argument("--log", default=None, help="Log file path (default: stdout)")
    args = parser.parse_args()

    logging.basicConfig(
        filename=args.log,
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(message)s",
    )

    working = Path(args.working_dir)
    if not working.is_dir():
        logging.error("Directory not found: %s", working)
        sys.exit(1)

    data_files = sorted(working.rglob("data.json"))
    if not data_files:
        logging.warning("No data.json files found under %s", working)
        return

    for path in data_files:
        logging.info("Splitting %s", path)
        out_dir = split_data_file(path)
        if out_dir:
            count = sum(1 for _ in out_dir.iterdir())
            logging.info("  → %s (%d records)", out_dir, count)
        else:
            logging.warning("  → skipped (empty file)")


if __name__ == "__main__":
    main()
